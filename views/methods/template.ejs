<%- include('../partials/header') %>

<div class="container mx-auto px-6 py-16 animate-fade-in max-w-6xl">
    <div class="mb-10">
        <a href="/methods" class="inline-flex items-center text-white/30 hover:text-white font-black text-xs tracking-[0.3em] uppercase transition-all duration-300 group mb-12">
            <span class="mr-4 group-hover:-translate-x-2 transition-transform">←</span> Return to Library
        </a>
        
        <div class="glass p-12 md:p-20 rounded-[3rem] relative overflow-hidden mb-12">
            <div class="absolute inset-0 pointer-events-none">
                <div class="absolute top-0 right-0 w-96 h-96 bg-nord8/5 rounded-full blur-[100px]"></div>
            </div>

            <div class="flex flex-col md:flex-row justify-between items-start mb-16 gap-8">
                <div>
                    <span class="inline-block px-6 py-2 rounded-full glass border border-white/5 text-[10px] font-black uppercase tracking-[0.3em] mb-8 text-nord8">
                        Specific Implementation
                    </span>
                    <h1 class="text-5xl md:text-6xl font-black text-white mb-6 tracking-tighter uppercase"><%= title %></h1>
                    <p class="text-xl text-nord4/60 font-light flex items-center">
                        <span class="w-8 h-px bg-white/10 mr-4"></span> <%= category %>
                    </p>
                </div>
                <button onclick="copyToClipboard()" class="bg-white hover:bg-nord8 text-black font-black py-5 px-12 rounded-2xl transition-all duration-300 transform hover:scale-105 active:scale-95 uppercase tracking-widest text-xs flex items-center shadow-2xl shadow-white/5">
                    <span id="copyIcon" class="mr-3">📋</span> <span id="copyText">COPY CODE</span>
                </button>
            </div>

            <!-- Explanation & UI Requirements -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-16">
                <div class="space-y-8">
                    <h3 class="text-xs font-black text-white/30 uppercase tracking-[0.4em] flex items-center">
                        <span class="w-8 h-px bg-white/10 mr-4"></span> Method Overview
                    </h3>
                    <div class="text-nord4/60 text-sm font-light leading-relaxed space-y-6">
                        <p><%= explanation %></p>
                        
                        <div class="glass p-8 rounded-3xl space-y-6">
                            <p class="text-white font-black text-xs tracking-widest uppercase">UI Requirements:</p>
                            <div class="space-y-4">
                                <% ui.forEach(item => { %>
                                    <div class="flex items-center justify-between p-4 bg-white/5 rounded-xl border border-white/5">
                                        <div>
                                            <span class="text-[10px] text-nord8 font-black uppercase block tracking-tighter"><%= item.element %></span>
                                            <span class="text-white font-bold tracking-wider"><%= item.name %></span>
                                        </div>
                                        <span class="text-[10px] text-nord4/40 font-medium uppercase"><%= item.role %></span>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="space-y-8">
                    <h3 class="text-xs font-black text-white/30 uppercase tracking-[0.4em] flex items-center">
                        <span class="w-8 h-px bg-white/10 mr-4"></span> Logic Dependencies
                    </h3>
                    <div class="glass p-8 rounded-3xl space-y-6">
                        <% if (refs && refs.length > 0) { %>
                            <div class="flex flex-wrap gap-4">
                                <% refs.forEach(ref => { %>
                                    <a href="/download/<%= category %>/<%= ref %>" class="flex-grow px-6 py-4 glass rounded-xl text-[10px] font-black text-nord8 uppercase tracking-[0.2em] hover:bg-white hover:text-black transition-all duration-300 flex items-center group">
                                        <span class="mr-3 group-hover:animate-bounce">⬇️</span> <%= ref %>
                                    </a>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <p class="text-nord4/40 text-xs font-light italic">No external reference files required.</p>
                        <% } %>
                    </div>

                    <h3 class="text-xs font-black text-white/30 uppercase tracking-[0.4em] flex items-center">
                        <span class="w-8 h-px bg-white/10 mr-4"></span> Implementation Note
                    </h3>
                    <p class="text-nord4/60 text-sm font-light leading-relaxed glass p-8 rounded-3xl">
                        Integrate these modules within your primary form events. Ensure all Guna UI names match your designer properties exactly to avoid runtime exceptions.
                    </p>
                </div>
            </div>

            <!-- Multiple Code Snippets -->
            <div class="space-y-12">
                <% fileContents.forEach((file, index) => { %>
                    <div class="space-y-6">
                        <div class="flex items-center justify-between">
                            <h3 class="text-xs font-black text-white/30 uppercase tracking-[0.4em] flex items-center">
                                <span class="w-8 h-px bg-white/10 mr-4"></span> [<%= index + 1 %>] <%= file.name %>
                            </h3>
                        </div>
                        <div class="relative group">
                            <div class="absolute -inset-px bg-gradient-to-r from-white/10 to-white/5 rounded-3xl"></div>
                            <div class="relative bg-black/40 backdrop-blur-xl p-10 md:p-16 rounded-3xl border border-white/5 overflow-hidden">
                                <pre class="overflow-x-auto text-sm md:text-base leading-relaxed text-nord4/80 font-mono scrollbar-thin" id="methodContent-<%= index %>"><code><%= file.content %></code></pre>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>
</div>

<script>
    function copyToClipboard() {
        // Copy the first code block by default, or all if needed. 
        // For multiple, usually users want one specific part.
        const content = document.getElementById('methodContent-0').innerText;
        navigator.clipboard.writeText(content).then(() => {
            const icon = document.getElementById('copyIcon');
            const text = document.getElementById('copyText');
            const btn = event.currentTarget;
            
            icon.innerText = '✅';
            text.innerText = 'COPIED';
            btn.classList.replace('bg-white', 'bg-nord14');
            
            setTimeout(() => {
                icon.innerText = '📋';
                text.innerText = 'COPY CODE';
                btn.classList.replace('bg-nord14', 'bg-white');
            }, 2000);
        });
    }
</script>

<%- include('../partials/header') %>
