<%- include('partials/header') %>

<div class="min-h-[90vh] flex flex-col items-center justify-center py-12 px-4 relative overflow-hidden">
    <!-- Ambient Background -->
    <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-nord8/5 rounded-full blur-[120px] animate-pulse"></div>
        <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-nord10/5 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s"></div>
    </div>

    <!-- Hero Content -->
    <div id="hero-section" class="text-center z-10">
        <div class="inline-block px-4 py-1.5 mb-8 rounded-full border border-white/10 bg-white/5 backdrop-blur-md text-nord8 text-xs font-black tracking-[0.3em] uppercase animate-fade-in">
            Next-Gen Game Cheat Development
        </div>
        <h1 class="text-7xl md:text-[10rem] font-black text-white mb-10 tracking-tighter leading-none select-none animate-glow">
            INTERNAL <span class="text-transparent bg-clip-text bg-gradient-to-b from-white to-white/20">X CHEATS</span>
        </h1>
        <p class="text-xl md:text-2xl text-nord4/60 max-w-2xl mx-auto mb-16 font-light leading-relaxed tracking-wide">
            Master C# and C++ with our translucent, high-performance guide designed for professional cheat developers.
        </p>
        
        <div class="flex flex-col sm:flex-row justify-center items-center gap-6">
            <button onclick="startStepForm()" class="group relative px-12 py-5 bg-white text-black font-black rounded-full overflow-hidden transition-all duration-500 hover:scale-105 active:scale-95 shadow-[0_0_40px_rgba(255,255,255,0.1)]">
                <span class="relative z-10 tracking-widest uppercase">Start Learning</span>
                <div class="absolute inset-0 bg-nord8 translate-y-full group-hover:translate-y-0 transition-transform duration-500"></div>
            </button>
            <a href="/about" class="px-12 py-5 bg-white/5 hover:bg-white/10 text-white font-bold rounded-full backdrop-blur-md border border-white/10 transition-all duration-300 hover:border-white/20 tracking-widest uppercase">
                Explore Docs
            </a>
        </div>
    </div>

    <!-- Step Form Modal -->
    <div id="step-form-container" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-6 bg-black/90 backdrop-blur-3xl transition-all duration-500">
        <div id="modal-box" class="bg-[#0a0a0a] w-full max-w-2xl rounded-[2.5rem] border border-white/5 p-10 md:p-16 relative shadow-2xl">
            <button onclick="closeStepForm()" class="absolute top-10 right-10 text-white/20 hover:text-white transition-colors">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
            
            <!-- Minimal Progress -->
            <div class="flex justify-center space-x-3 mb-16">
                <div id="dot-1" class="w-3 h-3 rounded-full bg-nord8 transition-all duration-500 shadow-[0_0_10px_rgba(136,192,208,0.5)]"></div>
                <div id="dot-2" class="w-3 h-3 rounded-full bg-white/10 transition-all duration-500"></div>
                <div id="dot-3" class="w-3 h-3 rounded-full bg-white/10 transition-all duration-500"></div>
            </div>

            <!-- Step 1: Discord -->
            <div id="step-1" class="step-content text-center">
                <h2 class="text-4xl font-black text-white mb-6 tracking-tight">Access Verification</h2>
                <p class="text-nord4/50 mb-12 text-lg font-light">Join our ecosystem to unlock advanced methods and logic.</p>
                <% if (user) { %>
                    <div class="bg-nord14/10 text-nord14 p-6 rounded-3xl border border-nord14/20 mb-10 flex items-center justify-center space-x-4">
                        <img src="<%= user.avatar ? `https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.png` : 'https://cdn.discordapp.com/embed/avatars/0.png' %>" class="w-10 h-10 rounded-full border border-white/10" alt="">
                        <span class="font-bold">Verified as <%= user.username %></span>
                    </div>
                    <button onclick="nextStep(2)" class="w-full py-5 bg-white text-black font-black rounded-2xl hover:bg-nord8 transition-colors uppercase tracking-widest">Proceed</button>
                <% } else { %>
                    <a href="/auth/discord" class="flex items-center justify-center w-full bg-[#5865F2] hover:bg-[#4752C4] text-white font-black py-6 rounded-2xl transition-all duration-300 shadow-xl group">
                        <svg class="w-6 h-6 mr-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037 19.736 19.736 0 0 0-4.885 1.515.069.069 0 0 0-.032.027C.533 9.048-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128c.126-.094.252-.192.372-.291a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
                        AUTH VIA DISCORD
                    </a>
                <% } %>
            </div>

            <!-- Step 2: Language -->
            <div id="step-2" class="step-content hidden text-center">
                <h2 class="text-4xl font-black text-white mb-6 tracking-tight">Core Architecture</h2>
                <p class="text-nord4/50 mb-12 text-lg font-light">Select your primary development language.</p>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <button onclick="selectLanguage('csharp')" class="p-12 bg-white/5 hover:bg-white/10 rounded-[2rem] border border-white/5 transition-all duration-300 group">
                        <span class="text-5xl block mb-6 group-hover:scale-110 transition-transform">🔷</span>
                        <span class="text-xl font-black text-white tracking-widest">C#</span>
                    </button>
                    <button onclick="selectLanguage('cpp')" class="p-12 bg-white/5 hover:bg-white/10 rounded-[2rem] border border-white/5 transition-all duration-300 group">
                        <span class="text-5xl block mb-6 group-hover:scale-110 transition-transform">⚙️</span>
                        <span class="text-xl font-black text-white tracking-widest">C++</span>
                    </button>
                </div>
            </div>

            <!-- Step 3: C# Options -->
            <div id="step-3-csharp" class="step-content hidden text-center">
                <h2 class="text-4xl font-black text-white mb-6 tracking-tight">Cheat Paradigm</h2>
                <p class="text-nord4/50 mb-12 text-lg font-light">Choose your specific implementation path.</p>
                <div class="space-y-4">
                    <button onclick="finishForm('csharp_external')" class="w-full p-6 bg-white/5 hover:bg-white text-white hover:text-black rounded-2xl border border-white/5 transition-all duration-300 text-left font-bold flex items-center justify-between group">
                        <span class="tracking-widest uppercase">External Cheat</span>
                        <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span>
                    </button>
                    <button onclick="selectLanguage('soon')" class="w-full p-6 bg-white/5 hover:bg-white text-white hover:text-black rounded-2xl border border-white/5 transition-all duration-300 text-left font-bold flex items-center justify-between group">
                        <span class="tracking-widest uppercase">Internal Cheat</span>
                        <span class="opacity-0 group-hover:opacity-100 transition-opacity">⏳</span>
                    </button>
                    <button onclick="selectLanguage('soon')" class="w-full p-6 bg-white/5 hover:bg-white text-white hover:text-black rounded-2xl border border-white/5 transition-all duration-300 text-left font-bold flex items-center justify-between group">
                        <span class="tracking-widest uppercase">Streamer Mode</span>
                        <span class="opacity-0 group-hover:opacity-100 transition-opacity">⏳</span>
                    </button>
                </div>
                <button onclick="nextStep(2)" class="mt-12 text-white/20 hover:text-white font-bold uppercase tracking-widest text-xs">← Back</button>
            </div>

            <!-- Under Development (Soon) -->
            <div id="step-soon" class="step-content hidden text-center">
                <div class="w-24 h-24 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-10 border border-white/10">
                    <span class="text-4xl animate-pulse">⏳</span>
                </div>
                <h2 class="text-4xl font-black text-white mb-6 tracking-tight">In Development</h2>
                <p class="text-nord4/50 mb-12 text-lg font-light leading-relaxed">This path is currently being documented. New internal logic and streamer guides are arriving soon.</p>
                <button onclick="nextStep(2)" class="px-12 py-5 bg-white text-black font-black rounded-full hover:bg-nord8 transition-colors uppercase tracking-widest">Return</button>
            </div>
        </div>
    </div>
</div>

<!-- Popular Categories Section -->
<div class="bg-black/20 py-20 border-y border-white/5">
    <div class="container mx-auto px-4">
        <h2 class="text-4xl font-black text-white mb-16 text-center tracking-tight">EXPLORE MODULES</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            <% categories.forEach(category => { %>
                <a href="/methods" class="glass p-8 rounded-3xl text-center transition-all duration-300 group">
                    <span class="text-nord8 text-4xl block mb-4 group-hover:scale-110 transition-transform">📁</span>
                    <span class="font-bold text-white/40 block uppercase tracking-widest text-[10px] group-hover:text-white transition-colors"><%= category %></span>
                </a>
            <% }) %>
        </div>
    </div>
</div>

<script>
    function startStepForm() {
        const container = document.getElementById('step-form-container');
        const box = document.getElementById('modal-box');
        container.classList.remove('hidden');
        box.classList.add('animate-modal');
        document.body.style.overflow = 'hidden';
        <% if (user) { %>
            nextStep(2);
        <% } else { %>
            nextStep(1);
        <% } %>
    }

    function closeStepForm() {
        const container = document.getElementById('step-form-container');
        const box = document.getElementById('modal-box');
        box.classList.remove('animate-modal');
        container.classList.add('hidden');
        document.body.style.overflow = 'auto';
    }

    function updateDots(step) {
        document.querySelectorAll('[id^="dot-"]').forEach((dot, i) => {
            if (i + 1 <= step) {
                dot.classList.replace('bg-white/10', 'bg-nord8');
                dot.classList.add('shadow-[0_0_10px_rgba(136,192,208,0.5)]');
            } else {
                dot.classList.replace('bg-nord8', 'bg-white/10');
                dot.classList.remove('shadow-[0_0_10px_rgba(136,192,208,0.5)]');
            }
        });
    }

    function nextStep(stepNum) {
        document.querySelectorAll('.step-content').forEach(s => s.classList.add('hidden'));
        updateDots(stepNum);
        
        if (stepNum === 1) {
            document.getElementById('step-1').classList.remove('hidden');
        } else if (stepNum === 2) {
            document.getElementById('step-2').classList.remove('hidden');
        }
    }

    function selectLanguage(lang) {
        document.querySelectorAll('.step-content').forEach(s => s.classList.add('hidden'));
        updateDots(3);
        
        if (lang === 'csharp') {
            document.getElementById('step-3-csharp').classList.remove('hidden');
        } else if (lang === 'cpp' || lang === 'soon') {
            document.getElementById('step-soon').classList.remove('hidden');
        }
    }

    function finishForm(option) {
        window.location.href = "/guide?path=" + option;
    }

    window.onload = () => {
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('login') === 'required') startStepForm();
    }
</script>

<%- include('partials/footer') %>
