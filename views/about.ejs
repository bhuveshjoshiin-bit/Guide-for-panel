<%- include('partials/header') %>

<div class="container mx-auto px-6 py-16 animate-fade-in max-w-5xl">
    <div class="glass p-16 md:p-24 rounded-[4rem] text-center relative overflow-hidden">
        <div class="absolute inset-0 pointer-events-none">
            <div class="absolute top-0 right-0 w-96 h-96 bg-nord8/5 rounded-full blur-[100px]"></div>
            <div class="absolute bottom-0 left-0 w-96 h-96 bg-nord10/5 rounded-full blur-[100px]"></div>
        </div>

        <div class="inline-block px-4 py-1.5 mb-10 rounded-full border border-white/10 bg-white/5 backdrop-blur-md text-nord8 text-[10px] font-black tracking-[0.4em] uppercase">
            Platform Vision
        </div>
        
        <h1 class="text-6xl md:text-8xl font-black text-white mb-10 tracking-tighter uppercase">
            About <span class="text-nord8">Project</span>
        </h1>
        
        <p class="text-2xl text-nord4/60 leading-relaxed mb-16 font-light max-w-3xl mx-auto">
            A high-performance ecosystem dedicated to the architecture and implementation of professional game panels.
        </p>

        <div class="h-px w-32 bg-white/10 mx-auto mb-16"></div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
            <div class="glass p-12 rounded-[3rem] glass-hover transition-all duration-500 group">
                <div class="w-16 h-16 bg-white/5 rounded-2xl flex items-center justify-center text-3xl mb-8 group-hover:scale-110 transition-transform">🎯</div>
                <h3 class="text-xl font-black text-white mb-6 uppercase tracking-widest">The Mission</h3>
                <p class="text-nord4/40 leading-relaxed font-light">
                    To bridge the gap between amateur and professional panel development through performance-first education and modular logic.
                </p>
            </div>
            <div class="glass p-12 rounded-[3rem] glass-hover transition-all duration-500 group">
                <div class="w-16 h-16 bg-white/5 rounded-2xl flex items-center justify-center text-3xl mb-8 group-hover:scale-110 transition-transform">💻</div>
                <h3 class="text-xl font-black text-white mb-6 uppercase tracking-widest">Modern Stack</h3>
                <p class="text-nord4/40 leading-relaxed font-light">
                    Leveraging Node.js for delivery and C#/C++ for execution. Built with glassmorphism and translucent paradigms.
                </p>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
